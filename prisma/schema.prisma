generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  OFFICE
  MECHANIC
  FIELD
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum ProjectContractType {
  PER_METER
  DAY_RATE
  LUMP_SUM
}

enum ProjectInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_COLLECTED
  COLLECTED
  VOID
}

enum RigStatus {
  ACTIVE
  IDLE
  MAINTENANCE
  BREAKDOWN
}

enum RigCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
}

enum RigCostAllocationBasis {
  DAY
  HOUR
}

enum MaintenanceStatus {
  OPEN
  IN_REPAIR
  WAITING_FOR_PARTS
  COMPLETED
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ApprovalDecision {
  APPROVED
  DENIED
  NEEDS_INFO
}

enum EntryApprovalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum DrillDelayReasonCategory {
  WEATHER
  RIG_BREAKDOWN
  RIG_MOVE_SETUP
  MATERIAL_SUPPLY_WAIT
  POWER_WATER_ISSUE
  SAFETY_PERMIT_HOLD
  SITE_ACCESS
  OTHER
}

enum InventoryItemStatus {
  ACTIVE
  INACTIVE
}

enum InventoryCategory {
  DRILLING
  HYDRAULIC
  ELECTRICAL
  CONSUMABLES
  TIRES
  OILS
  FILTERS
  SPARE_PARTS
  OTHER
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

enum InventoryUsageRequestStatus {
  SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum InventoryUsageRequestBatchStatus {
  SUBMITTED
  PENDING
  APPROVED
  REJECTED
  PARTIALLY_APPROVED
}

enum InventoryUsageRequestBatchLineStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

enum InventoryUsageContextType {
  DRILLING_REPORT
  MAINTENANCE
  BREAKDOWN
  OTHER
}

enum BudgetScopeType {
  RIG
  PROJECT
}

enum AlertResolutionStatus {
  OPEN
  RESOLVED
  SNOOZED
}

enum CopilotScopeMode {
  THIS_PAGE
  RELATED_DATA
  WHOLE_APP
}

enum CopilotChatRole {
  USER
  ASSISTANT
}

enum CopilotChatIntent {
  GENERAL_EXPLANATION
  APP_GUIDANCE
  NAVIGATION
  COMPARISON
  FOLLOW_UP_REFERENCE
  PAGE_SUMMARY
  WHOLE_APP_SUMMARY
}

model User {
  id                  String              @id @default(cuid())
  fullName            String
  email               String              @unique
  passwordHash        String
  role                UserRole
  roleId              String?
  phone               String?
  title               String?
  profileImageUrl     String?
  currentAssignment   String?
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  roleRef             Role?               @relation(fields: [roleId], references: [id])
  submittedReports    DrillReport[]       @relation("reportSubmitter")
  maintenanceLogs     MaintenanceUpdate[] @relation("maintenanceActor")
  approvals           Approval[]
  enteredExpenses     Expense[]           @relation("expenseEnteredBy")
  approvedExpenses    Expense[]           @relation("expenseApprover")
  approvedReports     DrillReport[]       @relation("reportApprover")
  submittedBreakdowns BreakdownReport[]   @relation("breakdownReporter")
  auditLogs           AuditLog[]          @relation("auditActor")
  inventoryMovements  InventoryMovement[] @relation("inventoryPerformedBy")
  inventoryUsageRequests InventoryUsageRequest[] @relation("inventoryUsageRequester")
  inventoryUsageDecisions InventoryUsageRequest[] @relation("inventoryUsageDecider")
  inventoryUsageRequestBatchesRequested InventoryUsageRequestBatch[] @relation("inventoryUsageBatchRequester")
  inventoryUsageRequestBatchesDecided InventoryUsageRequestBatch[] @relation("inventoryUsageBatchDecider")
  createdBudgetPlans  BudgetPlan[]        @relation("budgetPlanCreator")
  updatedBudgetPlans  BudgetPlan[]        @relation("budgetPlanUpdater")
  copilotChatThreads  CopilotChatThread[]
  createdProjectLaborEntries ProjectLaborEntry[] @relation("projectLaborEntryCreator")
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  users       User[]
}

model Client {
  id                 String               @id @default(cuid())
  name               String               @unique
  contactPerson      String?
  email              String?
  phone              String?
  description        String?
  address            String?
  logoUrl            String?
  profilePhotoUrl    String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  projects           Project[]
  drillReports       DrillReport[]
  revenues           Revenue[]
  expenses           Expense[]
  maintenance        MaintenanceRequest[]
  rigUsages          RigUsage[]
  breakdownReports   BreakdownReport[]
  inventoryMovements InventoryMovement[]
  budgetPlans        BudgetPlan[]
}

model Project {
  id                 String               @id @default(cuid())
  clientId           String
  name               String
  location           String
  description        String?
  photoUrl           String?
  startDate          DateTime
  endDate            DateTime?
  status             ProjectStatus        @default(PLANNED)
  contractType       ProjectContractType  @default(PER_METER)
  contractRatePerM   Float                @default(0)
  contractDayRate    Float                @default(0)
  contractLumpSumValue Float              @default(0)
  estimatedMeters    Float                @default(0)
  estimatedDays      Float                @default(0)
  assignedRigId      String?
  backupRigId        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  client             Client               @relation(fields: [clientId], references: [id])
  assignedRig        Rig?                 @relation("assignedRig", fields: [assignedRigId], references: [id])
  backupRig          Rig?                 @relation("backupRig", fields: [backupRigId], references: [id])
  rigUsage           RigUsage[]
  drillReports       DrillReport[]
  revenues           Revenue[]
  expenses           Expense[]
  maintenance        MaintenanceRequest[]
  summaryReports     SummaryReport[]
  breakdownReports   BreakdownReport[]
  inventoryMovements InventoryMovement[]
  inventoryUsageRequests InventoryUsageRequest[]
  inventoryUsageRequestBatches InventoryUsageRequestBatch[]
  budgetPlans        BudgetPlan[]
  changeOrders       ProjectChangeOrder[]
  laborEntries       ProjectLaborEntry[]
  invoices           ProjectInvoice[]
  billingRateItems   ProjectBillingRateItem[]
}

model ProjectBillingRateItem {
  id        String   @id @default(cuid())
  projectId String
  itemCode  String
  label     String
  unit      String
  unitRate  Float
  drillingStageLabel String?
  depthBandStartM Float?
  depthBandEndM Float?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, itemCode])
  @@index([projectId, sortOrder, createdAt])
}

model ProjectChangeOrder {
  id          String   @id @default(cuid())
  projectId   String
  description String
  addedValue  Float
  addedMeters Float?
  addedDays   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model ProjectInvoice {
  id            String               @id @default(cuid())
  projectId     String
  invoiceNumber String               @unique
  issueDate     DateTime
  dueDate       DateTime?
  amount        Float
  status        ProjectInvoiceStatus @default(DRAFT)
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payments      ProjectInvoicePayment[]

  @@index([projectId, issueDate])
  @@index([projectId, status, issueDate])
}

model ProjectInvoicePayment {
  id               String         @id @default(cuid())
  invoiceId        String
  paymentDate      DateTime
  amount           Float
  paymentReference String?
  paymentMethod    String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  invoice          ProjectInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, paymentDate])
}

model Rig {
  id                       String               @id @default(cuid())
  rigCode                  String               @unique
  model                    String
  serialNumber             String               @unique
  photoUrl                 String?
  acquisitionDate          DateTime?
  status                   RigStatus            @default(IDLE)
  condition                RigCondition         @default(GOOD)
  conditionScore           Int                  @default(80)
  totalHoursWorked         Float                @default(0)
  totalMetersDrilled       Float                @default(0)
  totalLifetimeDays        Int                  @default(0)
  costAllocationBasis      RigCostAllocationBasis @default(DAY)
  costRatePerDay           Float                @default(0)
  costRatePerHour          Float                @default(0)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  assignedProjects         Project[]            @relation("assignedRig")
  backupProjects           Project[]            @relation("backupRig")
  rigUsage                 RigUsage[]
  drillReports             DrillReport[]
  revenues                 Revenue[]
  expenses                 Expense[]
  maintenance              MaintenanceRequest[]
  inspections              Inspection[]
  breakdownReports         BreakdownReport[]
  inventoryMovements       InventoryMovement[]
  compatibleInventoryItems InventoryItem[]      @relation("itemCompatibleRig")
  inventoryUsageRequests   InventoryUsageRequest[]
  inventoryUsageRequestBatches InventoryUsageRequestBatch[]
  budgetPlans              BudgetPlan[]
  projectLaborEntries      ProjectLaborEntry[]
}

model ProjectLaborEntry {
  id              String   @id @default(cuid())
  projectId       String
  rigId           String?
  workDate        DateTime
  crewRole        String?
  personLabel     String?
  hoursWorked     Float
  hourlyRate      Float
  totalCost       Float
  notes           String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rig             Rig?     @relation(fields: [rigId], references: [id])
  createdBy       User?    @relation("projectLaborEntryCreator", fields: [createdByUserId], references: [id])

  @@index([projectId, workDate])
  @@index([rigId, workDate])
}

model RigUsage {
  id         String    @id @default(cuid())
  rigId      String
  projectId  String
  clientId   String
  startDate  DateTime
  endDate    DateTime?
  usageDays  Int       @default(0)
  usageHours Float     @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  rig        Rig       @relation(fields: [rigId], references: [id])
  project    Project   @relation(fields: [projectId], references: [id])
  client     Client    @relation(fields: [clientId], references: [id])
}

model DrillReport {
  id                 String              @id @default(cuid())
  date               DateTime
  clientId           String
  projectId          String
  rigId              String
  submittedById      String?
  submittedAt        DateTime?
  approvedById       String?
  approvalStatus     EntryApprovalStatus @default(SUBMITTED)
  approvedAt         DateTime?
  rejectionReason    String?
  holeNumber         String
  areaLocation       String
  fromMeter          Float
  toMeter            Float
  totalMetersDrilled Float
  workHours          Float
  rigMoves           Int                 @default(0)
  standbyHours       Float               @default(0)
  delayHours         Float               @default(0)
  delayReasonCategory DrillDelayReasonCategory?
  delayReasonNote    String?
  holeContinuityOverrideReason String?
  comments           String?
  operatorCrew       String?
  leadOperatorName   String?
  assistantCount     Int                 @default(0)
  billableAmount     Float               @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  client             Client              @relation(fields: [clientId], references: [id])
  project            Project             @relation(fields: [projectId], references: [id])
  rig                Rig                 @relation(fields: [rigId], references: [id])
  submittedBy        User?               @relation("reportSubmitter", fields: [submittedById], references: [id])
  approvedBy         User?               @relation("reportApprover", fields: [approvedById], references: [id])
  billableLines      DrillReportBillableLine[]
  inventoryUsageRequests InventoryUsageRequest[] @relation("drillReportUsageRequests")
  inventoryUsageRequestBatches InventoryUsageRequestBatch[] @relation("drillReportUsageRequestBatches")
  inventoryMovements InventoryMovement[] @relation("drillReportMovements")
}

model DrillReportBillableLine {
  id            String      @id @default(cuid())
  drillReportId String
  itemCode      String
  quantity      Float
  unit          String
  drillReport   DrillReport @relation(fields: [drillReportId], references: [id], onDelete: Cascade)

  @@index([drillReportId])
}

model Revenue {
  id        String   @id @default(cuid())
  date      DateTime
  amount    Float
  category  String
  clientId  String?
  projectId String?
  rigId     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client?  @relation(fields: [clientId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  rig       Rig?     @relation(fields: [rigId], references: [id])
}

model Expense {
  id                 String              @id @default(cuid())
  date               DateTime
  amount             Float
  category           String
  subcategory        String?
  entrySource        String              @default("SYSTEM")
  vendor             String?             @map("vendorName")
  receiptNumber      String?
  quantity           Float?
  unitCost           Float?
  receiptUrl         String?
  receiptFileName    String?
  enteredByUserId    String?             @map("submittedById")
  submittedAt        DateTime?
  approvedById       String?
  approvalStatus     EntryApprovalStatus @default(DRAFT)
  approvedAt         DateTime?
  rejectionReason    String?
  clientId           String?
  projectId          String?
  rigId              String?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  client             Client?             @relation(fields: [clientId], references: [id])
  project            Project?            @relation(fields: [projectId], references: [id])
  rig                Rig?                @relation(fields: [rigId], references: [id])
  enteredBy          User?               @relation("expenseEnteredBy", fields: [enteredByUserId], references: [id])
  approvedBy         User?               @relation("expenseApprover", fields: [approvedById], references: [id])
  inventoryMovements InventoryMovement[]
}

model AuditLog {
  id              String    @id @default(cuid())
  module          String
  entityType      String
  entityId        String
  action          String
  description     String?
  beforeValueJson String?
  afterValueJson  String?
  actorId         String?
  actorName       String?
  actorRole       UserRole?
  createdAt       DateTime  @default(now())
  actor           User?     @relation("auditActor", fields: [actorId], references: [id])

  @@index([createdAt])
  @@index([module, action])
  @@index([entityType, entityId])
}

model Mechanic {
  id                String               @id @default(cuid())
  fullName          String
  specialization    String
  phone             String?
  email             String?              @unique
  profileImageUrl   String?
  currentAssignment String?
  status            String               @default("AVAILABLE")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  maintenance       MaintenanceRequest[]
  inspections       Inspection[]
}

model MaintenanceRequest {
  id                   String              @id @default(cuid())
  requestCode          String              @unique
  requestDate          DateTime
  rigId                String
  clientId             String?
  projectId            String?
  breakdownReportId    String?
  mechanicId           String
  maintenanceType      String?
  issueDescription     String
  materialsNeeded      String
  urgency              UrgencyLevel
  photoUrls            String
  notes                String?
  estimatedDowntimeHrs Float               @default(0)
  status               MaintenanceStatus   @default(OPEN)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  rig                  Rig                 @relation(fields: [rigId], references: [id])
  client               Client?             @relation(fields: [clientId], references: [id])
  project              Project?            @relation(fields: [projectId], references: [id])
  breakdownReport      BreakdownReport?    @relation(fields: [breakdownReportId], references: [id])
  mechanic             Mechanic            @relation(fields: [mechanicId], references: [id])
  updates              MaintenanceUpdate[]
  approvals            Approval[]
  inventoryMovements   InventoryMovement[]
  inventoryUsageRequests InventoryUsageRequest[]
  inventoryUsageRequestBatches InventoryUsageRequestBatch[]

  @@index([breakdownReportId, requestDate])
}

model InventorySupplier {
  id            String              @id @default(cuid())
  name          String              @unique
  contactPerson String?
  email         String?
  phone         String?
  notes         String?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  items         InventoryItem[]
  movements     InventoryMovement[]

  @@index([name])
}

model InventoryLocation {
  id           String              @id @default(cuid())
  name         String              @unique
  description  String?
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  items        InventoryItem[]
  movementFrom InventoryMovement[] @relation("movementLocationFrom")
  movementTo   InventoryMovement[] @relation("movementLocationTo")
  usageRequests InventoryUsageRequest[]
  usageRequestBatches InventoryUsageRequestBatch[]

  @@index([name])
}

model InventoryItem {
  id                String              @id @default(cuid())
  name              String
  sku               String              @unique
  category          InventoryCategory
  description       String?
  quantityInStock   Float               @default(0)
  minimumStockLevel Float               @default(0)
  unitCost          Float               @default(0)
  supplierId        String?
  locationId        String?
  compatibleRigId   String?
  compatibleRigType String?
  partNumber        String?
  status            InventoryItemStatus @default(ACTIVE)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  supplier          InventorySupplier?  @relation(fields: [supplierId], references: [id])
  location          InventoryLocation?  @relation(fields: [locationId], references: [id])
  compatibleRig     Rig?                @relation("itemCompatibleRig", fields: [compatibleRigId], references: [id])
  movements         InventoryMovement[]
  usageRequests     InventoryUsageRequest[]
  usageRequestBatchLines InventoryUsageRequestBatchLine[]

  @@index([category])
  @@index([status])
  @@index([name])
}

model InventoryMovement {
  id                    String                @id @default(cuid())
  itemId                String
  movementType          InventoryMovementType
  contextType           InventoryUsageContextType?
  quantity              Float
  unitCost              Float?
  totalCost             Float?
  date                  DateTime
  performedByUserId     String?
  clientId              String?
  rigId                 String?
  projectId             String?
  drillReportId         String?
  maintenanceRequestId  String?
  breakdownReportId     String?
  expenseId             String?
  supplierId            String?
  locationFromId        String?
  locationToId          String?
  traReceiptNumber      String?
  supplierInvoiceNumber String?
  receiptUrl            String?
  receiptFileName       String?
  notes                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  item                  InventoryItem         @relation(fields: [itemId], references: [id])
  performedBy           User?                 @relation("inventoryPerformedBy", fields: [performedByUserId], references: [id])
  client                Client?               @relation(fields: [clientId], references: [id])
  rig                   Rig?                  @relation(fields: [rigId], references: [id])
  project               Project?              @relation(fields: [projectId], references: [id])
  drillReport           DrillReport?          @relation("drillReportMovements", fields: [drillReportId], references: [id], onDelete: SetNull)
  maintenanceRequest    MaintenanceRequest?   @relation(fields: [maintenanceRequestId], references: [id])
  breakdownReport       BreakdownReport?      @relation(fields: [breakdownReportId], references: [id])
  expense               Expense?              @relation(fields: [expenseId], references: [id])
  supplier              InventorySupplier?    @relation(fields: [supplierId], references: [id])
  locationFrom          InventoryLocation?    @relation("movementLocationFrom", fields: [locationFromId], references: [id])
  locationTo            InventoryLocation?    @relation("movementLocationTo", fields: [locationToId], references: [id])

  @@index([itemId, date])
  @@index([movementType, date])
  @@index([rigId, projectId, date])
  @@index([drillReportId, date])
  @@index([maintenanceRequestId, date])
  @@index([breakdownReportId, date])
}

model InventoryUsageRequest {
  id                String                      @id @default(cuid())
  itemId            String
  contextType       InventoryUsageContextType   @default(OTHER)
  quantity          Float
  reason            String
  projectId         String?
  rigId             String?
  drillReportId     String?
  maintenanceRequestId String?
  breakdownReportId String?
  locationId        String?
  requestedForDate  DateTime?
  requestedById     String?
  status            InventoryUsageRequestStatus @default(SUBMITTED)
  decisionNote      String?
  decidedById       String?
  decidedAt         DateTime?
  approvedMovementId String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  item              InventoryItem               @relation(fields: [itemId], references: [id])
  project           Project?                    @relation(fields: [projectId], references: [id])
  rig               Rig?                        @relation(fields: [rigId], references: [id])
  drillReport       DrillReport?                @relation("drillReportUsageRequests", fields: [drillReportId], references: [id], onDelete: SetNull)
  maintenanceRequest MaintenanceRequest?        @relation(fields: [maintenanceRequestId], references: [id])
  breakdownReport   BreakdownReport?            @relation(fields: [breakdownReportId], references: [id])
  location          InventoryLocation?          @relation(fields: [locationId], references: [id])
  requestedBy       User?                       @relation("inventoryUsageRequester", fields: [requestedById], references: [id])
  decidedBy         User?                       @relation("inventoryUsageDecider", fields: [decidedById], references: [id])

  @@index([status, createdAt])
  @@index([itemId, createdAt])
  @@index([projectId, rigId, locationId])
  @@index([drillReportId, requestedForDate])
  @@index([maintenanceRequestId, requestedForDate])
  @@index([breakdownReportId, requestedForDate])
}

model InventoryUsageRequestBatch {
  id                   String                           @id @default(cuid())
  contextType          InventoryUsageContextType        @default(OTHER)
  reason               String?
  projectId            String?
  rigId                String?
  drillReportId        String?
  maintenanceRequestId String?
  breakdownReportId    String?
  locationId           String?
  requestedForDate     DateTime?
  requestedById        String?
  status               InventoryUsageRequestBatchStatus @default(SUBMITTED)
  decidedById          String?
  decidedAt            DateTime?
  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt
  project              Project?                         @relation(fields: [projectId], references: [id])
  rig                  Rig?                             @relation(fields: [rigId], references: [id])
  drillReport          DrillReport?                     @relation("drillReportUsageRequestBatches", fields: [drillReportId], references: [id], onDelete: SetNull)
  maintenanceRequest   MaintenanceRequest?              @relation(fields: [maintenanceRequestId], references: [id])
  breakdownReport      BreakdownReport?                 @relation(fields: [breakdownReportId], references: [id])
  location             InventoryLocation?               @relation(fields: [locationId], references: [id])
  requestedBy          User?                            @relation("inventoryUsageBatchRequester", fields: [requestedById], references: [id])
  decidedBy            User?                            @relation("inventoryUsageBatchDecider", fields: [decidedById], references: [id])
  lines                InventoryUsageRequestBatchLine[]

  @@index([status, createdAt])
  @@index([projectId, rigId, locationId])
  @@index([drillReportId, requestedForDate])
  @@index([maintenanceRequestId, requestedForDate])
  @@index([breakdownReportId, requestedForDate])
}

model InventoryUsageRequestBatchLine {
  id               String                               @id @default(cuid())
  batchId          String
  itemId           String
  quantity         Float
  status           InventoryUsageRequestBatchLineStatus @default(SUBMITTED)
  decisionNote     String?
  approvedMovementId String?
  createdAt        DateTime                             @default(now())
  updatedAt        DateTime                             @updatedAt
  batch            InventoryUsageRequestBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  item             InventoryItem                        @relation(fields: [itemId], references: [id])

  @@unique([batchId, itemId])
  @@index([status, createdAt])
  @@index([itemId, createdAt])
  @@index([batchId, status])
}

model MaintenanceUpdate {
  id                 String             @id @default(cuid())
  maintenanceId      String
  actorUserId        String
  previousStatus     MaintenanceStatus?
  newStatus          MaintenanceStatus
  updateNote         String
  createdAt          DateTime           @default(now())
  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceId], references: [id])
  actor              User               @relation("maintenanceActor", fields: [actorUserId], references: [id])
}

model Inspection {
  id                 String       @id @default(cuid())
  rigId              String
  mechanicId         String
  inspectionDate     DateTime
  condition          RigCondition
  conditionScore     Int
  findings           String
  recommendedActions String?
  createdAt          DateTime     @default(now())
  rig                Rig          @relation(fields: [rigId], references: [id])
  mechanic           Mechanic     @relation(fields: [mechanicId], references: [id])
}

model Approval {
  id                 String             @id @default(cuid())
  maintenanceId      String
  approverId         String
  decision           ApprovalDecision
  note               String?
  createdAt          DateTime           @default(now())
  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceId], references: [id])
  approver           User               @relation(fields: [approverId], references: [id])
}

model SummaryReport {
  id            String   @id @default(cuid())
  reportDate    DateTime
  reportType    String
  clientId      String?
  projectId     String?
  payloadJson   String
  generatedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project? @relation(fields: [projectId], references: [id])

  @@index([reportType, reportDate])
}

model BreakdownReport {
  id            String       @id @default(cuid())
  reportDate    DateTime     @default(now())
  reportedById  String
  rigId         String
  projectId     String
  clientId      String
  title         String
  description   String
  severity      UrgencyLevel @default(MEDIUM)
  downtimeHours Float        @default(0)
  status        String       @default("SUBMITTED")
  photoUrls     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  reportedBy    User         @relation("breakdownReporter", fields: [reportedById], references: [id])
  rig           Rig          @relation(fields: [rigId], references: [id])
  project       Project      @relation(fields: [projectId], references: [id])
  client        Client       @relation(fields: [clientId], references: [id])
  maintenanceRequests MaintenanceRequest[]
  inventoryUsageRequests InventoryUsageRequest[]
  inventoryUsageRequestBatches InventoryUsageRequestBatch[]
  inventoryMovements InventoryMovement[]
}

model BudgetPlan {
  id          String          @id @default(cuid())
  scopeType   BudgetScopeType
  name        String
  amount      Float
  currency    String          @default("USD")
  periodStart DateTime
  periodEnd   DateTime
  isActive    Boolean         @default(true)
  notes       String?
  clientId    String?
  projectId   String?
  rigId       String?
  createdById String
  updatedById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  client      Client?         @relation(fields: [clientId], references: [id])
  project     Project?        @relation(fields: [projectId], references: [id])
  rig         Rig?            @relation(fields: [rigId], references: [id])
  createdBy   User            @relation("budgetPlanCreator", fields: [createdById], references: [id])
  updatedBy   User            @relation("budgetPlanUpdater", fields: [updatedById], references: [id])

  @@index([scopeType, rigId, isActive, periodStart, periodEnd])
  @@index([scopeType, projectId, isActive, periodStart, periodEnd])
  @@index([clientId, isActive, periodStart, periodEnd])
}

model AlertCenterState {
  id               String                @id @default(cuid())
  alertKey         String                @unique
  status           AlertResolutionStatus @default(OPEN)
  snoozedUntil     DateTime?
  resolvedAt       DateTime?
  resolvedByUserId String?
  note             String?
  metadataJson     String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([status, updatedAt])
  @@index([resolvedAt])
  @@index([snoozedUntil])
}

model CopilotChatThread {
  id             String            @id @default(cuid())
  userId         String
  title          String
  scopeMode      CopilotScopeMode  @default(THIS_PAGE)
  currentPageKey String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       CopilotChatMessage[]

  @@index([userId, updatedAt])
  @@index([scopeMode, updatedAt])
}

model CopilotChatMessage {
  id               String             @id @default(cuid())
  threadId         String
  role             CopilotChatRole
  intent           CopilotChatIntent?
  content          String
  pageKey          String?
  scopeMode        CopilotScopeMode?
  contextJson      String?
  responseDataJson String?
  createdAt        DateTime           @default(now())
  thread           CopilotChatThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([intent, createdAt])
}
