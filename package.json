{
  "name": "geofields-operations-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run db:doctor",
    "dev": "node --import tsx scripts/dev-server.ts",
    "dev:clean": "rm -rf .next .next-dev .next-dev-*",
    "dev:reset": "npm run -s db:doctor && node --import tsx scripts/dev-reset-runtime.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --cache --cache-location .next-build/eslintcache",
    "typecheck": "rm -f tsconfig.tsbuildinfo && NEXT_DIST_DIR=.next-build next typegen && tsc --noEmit",
    "smoke:critical": "npx tsx scripts/smoke-critical-workflows.ts",
    "smoke:consistency": "npx tsx scripts/smoke-financial-consistency.ts",
    "smoke:ops": "npx tsx scripts/smoke-operational-lifecycle.ts",
    "smoke:mutations": "npx tsx scripts/smoke-mutation-hardening.ts",
    "test:module-boundaries": "node --import tsx scripts/test-extracted-module-boundaries.ts",
    "test:interaction:workflows": "node --import tsx scripts/test-interaction-workflows.ts",
    "test:contract:spending": "node --import tsx scripts/test-spending-contracts.ts",
    "smoke:spending-first": "node --import tsx scripts/smoke-spending-first.ts",
    "bundle:guard": "node --import tsx scripts/bundle-guard.ts",
    "build:guard": "NEXT_DIST_DIR=.next-build next build && NEXT_DIST_DIR=.next-build node --import tsx scripts/bundle-guard.ts",
    "preflight:local": "node --import tsx scripts/preflight-local.ts",
    "hygiene:check": "npx tsx scripts/hygiene-check.ts",
    "arch:guard": "npx tsx scripts/architecture-guard.ts",
    "quality:static": "npm run typecheck && npm run lint && npm run hygiene:check && npm run arch:guard",
    "quality:gate": "npm run quality:static && npm run smoke:critical && npm run smoke:consistency && npm run smoke:ops && npm run smoke:mutations && npm run test:contract:spending",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:doctor": "node --import tsx scripts/db-doctor.ts",
    "db:sync": "npm run db:doctor && npm run db:push && npm run db:generate",
    "db:refresh:demo": "npm run db:sync && npm run db:seed",
    "db:migrate": "prisma migrate dev",
    "db:backfill:legacy-usage": "node --import tsx scripts/backfill-legacy-usage-linkage.ts",
    "db:seed": "node --import tsx prisma/seed.ts",
    "predb:push": "npm run db:doctor",
    "predb:seed": "npm run db:doctor",
    "predb:migrate": "npm run db:doctor"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@zxing/library": "^0.21.3",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.2",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.511.0",
    "next": "^15.2.4",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.13.8",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.2.4",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
