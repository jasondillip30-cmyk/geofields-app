DATABASE_URL="file:./dev.db"
AUTH_SECRET="change-this-to-a-long-random-secret"
NEXT_PUBLIC_ENABLE_WORKSPACE_LAUNCH="true"
NEXT_PUBLIC_ENABLE_FORECASTING="false"

# Receipt extractor mode:
# local  = current in-process extraction (default)
# shadow = local response + background remote call for telemetry
# remote = remote extractor first, then local fallback on failure
RECEIPT_EXTRACTOR_MODE="local"
RECEIPT_EXTRACTOR_BASE_URL=""
RECEIPT_EXTRACTOR_API_KEY=""
RECEIPT_EXTRACTOR_TIMEOUT_MS="90000"
RECEIPT_EXTRACTOR_RETRY_COUNT="1"
RECEIPT_QR_TRACE="0"

# Dedicated receipt-extractor service runtime settings
EXTRACTOR_API_KEY=""
EXTRACTOR_MAX_UPLOAD_MB="20"
EXTRACTOR_MAX_LONG_EDGE_PX="3200"
EXTRACTOR_JPEG_QUALITY="92"
EXTRACTOR_LOCAL_STORAGE_DIR="./tmp/receipt-extractor-artifacts"
EXTRACTOR_STORAGE_PUBLIC_BASE_URL=""
SERVICE_VERSION="0.1.0"
